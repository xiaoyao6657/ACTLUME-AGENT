OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
AGENT_MAX_STEPS=10
AGENT_MEMORY_DIR=.agent-memory
AGENT_READONLY=false
AGENT_MCP_CONFIG=
# Optional: set a default target workspace for file/search/shell tools.
# AGENT_WORKSPACE=D:\workspace\some-project
# Optional: these values can also live in .actlume/config.json or ~/.actlume/config.json.
