{
  "servers": {
    "web_search": {
      "disabled": true,
      "command": "npx",
      "args": ["-y", "some-web-search-mcp-server"],
      "env": {
        "SEARCH_API_KEY": "your_key_here"
      },
      "cwd": ".",
      "toolPrefix": "mcp_search",
      "startupTimeoutMs": 15000,
      "toolTimeoutMs": 60000
    },
    "fetch": {
      "disabled": true,
      "command": "npx",
      "args": ["-y", "some-fetch-mcp-server"],
      "env": {},
      "cwd": ".",
      "toolPrefix": "mcp_fetch",
      "startupTimeoutMs": 15000,
      "toolTimeoutMs": 60000
    }
  }
}
